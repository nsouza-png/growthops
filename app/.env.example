# ─── Supabase (obrigatório) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# URL do connection pooler (recomendado em produção — porta 6543, transaction mode)
# Encontre em: Supabase Dashboard > Settings > Database > Connection Pooling
VITE_SUPABASE_POOLER_URL=https://<project>.pooler.supabase.com:6543

# ---- OpenAI ChatGPT (agora seguro no backend) -------------------------------
# NOTA: API key agora está segura nas Supabase Edge Functions
# Não é mais necessário expor no frontend
# Configure OPENAI_API_KEY nos secrets do Supabase Dashboard

# ─── Sentry — Error Tracking (recomendado em produção) ───────────────────────
# Sem esse valor o monitoring é desabilitado silenciosamente (não quebra o app)
# Obtenha em: https://sentry.io > New Project > React
VITE_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Growth Ops Revenue
VITE_APP_VERSION=1.0.0

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_SLACK_INTEGRATION=false
